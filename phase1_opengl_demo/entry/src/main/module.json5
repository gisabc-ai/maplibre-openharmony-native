{
  "module": {
    "name": "maplibre_ohos",
    "type": "entry",
    "description": "MapLibre GL Native for OpenHarmony",
    "mainElement": "MainAbility",
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1"
    ],
    "deliveryWithInstall": true,
    "pages": "$profile:main_pages",
    "abilities": [
      {
        "name": "MainAbility",
        "srcEntry": "./ets/MainAbility/Index.ets",
        "description": "$string:main_ability_description",
        "icon": "$media:icon",
        "label": "$string:app_name",
        "startWindowIcon": "$media:icon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "action.system.home"
            ]
          }
        ]
      }
    ],
    "dependencies": [],
    "nativenav": {
      "nativeLibDependencies": [
        "libmaplibre_ohos.so"
      ],
      "srcPath": [
        "./src/main/cpp"
      ]
    }
  }
}
