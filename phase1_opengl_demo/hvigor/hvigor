#!/bin/bash
#
# hvigor wrapper script for Linux/macOS
#
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# OpenHarmony SDK
OHOS_SDK_HOME="${OHOS_SDK_HOME:-$HOME/oh-sdk}"
export OHOS_SDK_HOME

# Find node_modules .bin hvigor
if [ -f "$PROJECT_DIR/node_modules/.bin/hvigor" ]; then
    echo "Using local hvigor from node_modules"
    exec "$PROJECT_DIR/node_modules/.bin/hvigor" "$@"
elif [ -f "$PROJECT_DIR/node_modules/@ohos/hvigor/hvigorw" ]; then
    echo "Using local hvigorw"
    exec "$PROJECT_DIR/node_modules/@ohos/hvigor/hvigorw" "$@"
elif [ -f "$OHOS_SDK_HOME/toolchains/hvigor/bin/hvigor" ]; then
    echo "Using SDK hvigor"
    exec "$OHOS_SDK_HOME/toolchains/hvigor/bin/hvigor" "$@"
elif which hvigor >/dev/null 2>&1; then
    echo "Using system hvigor"
    exec hvigor "$@"
else
    echo "Error: hvigor not found."
    echo "OHOS_SDK_HOME: $OHOS_SDK_HOME"
    echo "PROJECT_DIR: $PROJECT_DIR"
    echo "node_modules: $(ls $PROJECT_DIR/node_modules/.bin/ 2>/dev/null | head -5)"
    echo "SDK toolchains: $(ls $OHOS_SDK_HOME/toolchains/ 2>/dev/null)"
    exit 1
fi
